generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model ReceivedLetter {
  id             Int       @id @default(autoincrement()) @map("#")
  subject        String    @map("بابەت")
  department     String    @map("لایەنی پەیوەندیدار گشتی")
  departments    String[]  @default([]) @map("لایەنە پەیوەندیدارەکان")
  dept1          String?   @map("لایەنی پەیوەندیدار 1")
  dept2          String?   @map("لایەنی پەیوەندیدار 2")
  dept3          String?   @map("لایەنی پەیوەندیدار 3")
  refCode        String    @map("جۆر")
  letterType     String    @map("جۆری نامە")
  sentDate       DateTime? @map("ڕۆژی ناردن")
  responseDate   DateTime? @map("ڕۆژی وەڵام")
  processingTime Int?      @map("تێبینی")
  slaTime        String    @map("کاتی تێچوو بەپێی ڕێنمایی")

  createdAt      DateTime  @default(now()) @map("کاتی دروستکردن")
  updatedAt      DateTime  @updatedAt @map("کاتی نوێکردنەوە")

  @@map("وەڵامی_نووسراوە_نێردراوەکان")
}

model SentLetter {
  id             Int       @id @default(autoincrement()) @map("#")
  subject        String    @map("بابەت")
  department     String    @map("لایەنی پەیوەندیدار گشتی")
  departments    String[]  @default([]) @map("لایەنە پەیوەندیدارەکان")
  dept1          String?   @map("لایەنی پەیوەندیدار 1")
  dept2          String?   @map("لایەنی پەیوەندیدار 2")
  dept3          String?   @map("لایەنی پەیوەندیدار 3")
  refCode        String    @map("جۆر")
  letterType     String    @map("جۆری نامە")
  sentDate       DateTime? @map("ڕۆژی ناردن")

  createdAt      DateTime  @default(now()) @map("کاتی دروستکردن")
  updatedAt      DateTime  @updatedAt @map("کاتی نوێکردنەوە")

  @@map("سەرجەم_نووسراوە_ڕەوانەکراوەکان")
}

model IncomingLetter {
  id             Int       @id @default(autoincrement()) @map("#")
  subject        String    @map("بابەت")
  sender         String?   @map("هاتووە لە")
  department     String    @map("لایەنی پەیوەندیدار گشتی")
  departments    String[]  @default([]) @map("لایەنە پەیوەندیدارەکان")
  dept1          String?   @map("لایەنی پەیوەندیدار 1")
  dept2          String?   @map("لایەنی پەیوەندیدار 2")
  dept3          String?   @map("لایەنی پەیوەندیدار 3")
  refCode        String    @map("جۆر")
  letterType     String    @map("جۆری نامە")
  sentDate       DateTime? @map("ڕۆژی ناردن")

  createdAt      DateTime  @default(now()) @map("کاتی دروستکردن")
  updatedAt      DateTime  @updatedAt @map("کاتی نوێکردنەوە")

  @@map("سەرجەم_نووسراوە_هاتووەکان")
}

model UserAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      String   @default("user")
  status    String   @default("pending") // pending, approved, active
  authCode  String?
  createdAt DateTime @default(now())
}

model ActiveSession {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  role        String
  activeView  String
  lastActive  DateTime @default(now())
  hasData     Boolean  @default(false)
  sessionData SessionData?
}

model SessionData {
  userId       String        @id
  data         Json
  sentData     Json
  incomingData Json?         @default("[]")
  updatedAt    DateTime      @updatedAt
  session   ActiveSession @relation(fields: [userId], references: [userId], onDelete: Cascade)
}
