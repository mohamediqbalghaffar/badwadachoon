generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ReceivedLetter {
  id             Int       @id @default(autoincrement())
  subject        String
  department     String
  departments    String    @default("[]")
  dept1          String?
  dept2          String?
  dept3          String?
  refCode        String
  letterType     String
  sentDate       DateTime?
  responseDate   DateTime?
  processingTime Int?
  slaTime        String

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SentLetter {
  id             Int       @id @default(autoincrement())
  subject        String
  department     String
  departments    String    @default("[]")
  dept1          String?
  dept2          String?
  dept3          String?
  refCode        String
  letterType     String
  sentDate       DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model IncomingLetter {
  id             Int       @id @default(autoincrement())
  subject        String
  sender         String?
  department     String
  departments    String    @default("[]")
  dept1          String?
  dept2          String?
  dept3          String?
  refCode        String
  letterType     String
  sentDate       DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UserAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  role         String   @default("user")
  status       String   @default("pending") // pending, approved, active
  authCode     String?
  odooUrl      String?
  odooDb       String?
  odooUsername String?
  odooApiKey   String?
  createdAt    DateTime @default(now())
}

model ActiveSession {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  role        String
  activeView  String
  lastActive  DateTime @default(now())
  hasData     Boolean  @default(false)
  sessionData SessionData?
}

model SessionData {
  userId       String        @id
  data         String
  sentData     String
  incomingData String?       @default("[]")
  updatedAt    DateTime      @updatedAt
  session      ActiveSession @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model RolePermission {
  role        String   @id
  permissions String
  updatedAt   DateTime @updatedAt
}

